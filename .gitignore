# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# large media source files
*.mp4
!public/hero/hero-loop.mp4
.pnpm-debug.log*

# generated scraper output
/data/product-images/
/scripts/*/data/*-catalog.json
/scripts/*/data/*-progress.json
/scripts/*/data/image-download-progress.json
/scripts/*/data/*-failed.json
/scripts/*/data/*-product-urls.txt
/scripts/*/data/product-images/
/scripts/*/product-images/

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
